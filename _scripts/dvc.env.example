# B2 application key for DVC (Backblaze B2 S3-compatible API)
# Real file: /etc/dvc-env on the cron host (mode 600). Or pass
# DVC_ENV_FILE=/path/to/dvc-env to the snapshot script.
#
# Create the key in the B2 web UI:
#   App Keys → Create Key → bucketName=data-insights-raw
#   capabilities: listFiles, readFiles, writeFiles
# The S3 endpoint URL is shown in the B2 UI under the bucket's
# "Endpoint" tab. It is region-specific (e.g. s3.ca-east-006.backblazeb2.com
# for a Canadian bucket).
#
# DVC's S3 backend reads standard AWS env vars (boto3). The values
# below are exported as AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
# by _scripts/dvc_onboard.sh. The endpoint URL + bucket go into
# .dvc/config (committed). The key + secret stay in this file
# (mode 600, never committed).

B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_S3_ENDPOINT=https://s3.ca-east-006.backblazeb2.com
B2_BUCKET=data-insights-raw
