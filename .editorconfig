root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,csv,yml,yaml,toml}]
indent_size = 2

[*.{py,pyi}]
indent_size = 4
max_line_length = 100

[*.{r,R}]
indent_size = 2

[Makefile]
indent_style = tab
